# Cadence environment configuration
# Copy to .env for local development. On DirectAdmin / Passenger hosting,
# set these in the hosting panel instead — panel env vars take precedence over .env.

# Local dev only — Passenger assigns PORT on production; do not set PORT in the hosting panel.
PORT=3000
APP_NAME=Cadence

# Public site URL (required in production for CORS + startup logs)
# Example: https://chat.example.com
PUBLIC_URL=

# Comma-separated super admins (full access to admin panel + bypass all perms)
SUPER_ADMIN_USERNAMES=admin@galerie.local,manager@galerie.local

# Storage limits
MAX_STORAGE_GB=20
MAX_FILE_MB=100

# CORS / Socket.IO origins (comma-separated). Include your production HTTPS URL.
# Local .test / .local vhosts are auto-allowed in development.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Set false when serving production over plain HTTP (cookies won't use Secure flag)
# COOKIE_SECURE=false

# Optional bind address (standalone mode only; Passenger manages the socket)
# HOST=0.0.0.0

# Chat limits
MAX_MESSAGES_PER_ROOM=300
MAX_PINNED_PER_ROOM=20

# Rate limits
RATE_LIMIT_REGISTER=8
RATE_LIMIT_LOGIN=10
RATE_LIMIT_MESSAGES=30
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MSG_WINDOW_SEC=10

# Feature flags
REGISTRATION_ENABLED=true
GUEST_CHAT_ENABLED=true
MAINTENANCE_MODE=false

# Default rooms on fresh start (comma-separated)
DEFAULT_ROOMS=General,Random

# Optional SQLite path (default: data/cadence.db)
# DATABASE_PATH=

# Content moderation (NSFWJS — images + screen-record frames)
NSFW_ENABLED=true
NSFW_PORN_THRESHOLD=0.6
NSFW_SEXY_THRESHOLD=0.75
# Block uploads if server model fails to load (production recommended)
NSFW_STRICT=false
# Strikes before temporary lockout (default: 5 blocked uploads)
NSFW_MAX_STRIKES=5
# Minutes user is signed out and cannot log in (default: 10)
NSFW_LOCKOUT_MINUTES=10

# Behind a reverse proxy (DirectAdmin, nginx, etc.) set TRUST_PROXY=true so
# moderation lockouts use the real client IP from X-Forwarded-For.
# TRUST_PROXY=true

# Signed access-gate tokens (min 16 chars). Required in production.
# GATE_SECRET=

# --- Automated deploy (production server) ---
# Shared secret for POST /api/deploy/webhook (GitHub Actions or GitHub webhook)
DEPLOY_WEBHOOK_SECRET=
# Branch to pull on deploy (default: main)
# DEPLOY_BRANCH=main
